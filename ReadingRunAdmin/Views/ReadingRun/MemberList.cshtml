@{
    ViewData["Title"] = "리딩런 회원관리";
}

<div class="main-wrap">
  <div class="top-bar">
    <div class="breadcrumb">회원관리 &gt; <strong>리딩런 회원관리</strong></div>
    <div style="font-size:13px;color:#475569;font-weight:500;">관리자</div>
  </div>
  <div class="content-wrap">

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h1 class="page-title">리딩런 회원관리</h1>
    </div>

    <div class="search-box">
      <div><label class="form-label">검색 조건</label>
        <div style="display:flex;gap:4px;">
          <select id="fField" class="form-select" style="width:120px;">
            <option value="Member_Id">회원 ID</option>
            <option value="Member_No">회원 번호</option>
          </select>
          <input type="text" id="fKeyword" class="form-input" style="width:160px;" placeholder="검색어 입력"/>
        </div>
      </div>
      <div><label class="form-label">현재 코스</label>
        <select id="fCourse" class="form-select" style="width:120px;">
          <option value="">전체</option><option>Starter</option><option>Half</option><option>Marathon</option>
        </select>
      </div>
      <div><label class="form-label">가입일</label>
        <div style="display:flex;align-items:center;gap:4px;">
          <input type="date" id="fStart" class="form-input" style="width:140px;" value="2026-03-01"/>
          <span style="color:#94a3b8;">~</span>
          <input type="date" id="fEnd" class="form-input" style="width:140px;" value="2026-04-11"/>
        </div>
      </div>
      <div style="display:flex;gap:6px;align-items:flex-end;">
        <button class="btn btn-primary" onclick="doSearch()">검색</button>
        <button class="btn btn-secondary" onclick="doReset()">초기화</button>
        <button class="btn btn-success" onclick="BO.toast('엑셀 다운로드 요청되었습니다.','success')">↓ 엑셀 다운로드</button>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <span style="font-size:13px;color:#475569;">총 <strong id="totalCnt">0</strong>건</span>
      </div>
      <div style="overflow-x:auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>번호</th><th>회원 ID</th><th>현재 코스</th>
              <th>총 독서 시간(분)</th><th>누적 거리(km)</th><th>완주 횟수</th>
              <th>마지막 활동일시</th><th>가입일시</th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
      <div id="pagination"></div>
    </div>

  </div>
</div>

@section Scripts {
  <script src="~/js/member-list.js" asp-append-version="true"></script>
  <script>loadSidebar('member-list');</script>
}
