<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>@ViewData["Title"] - 리딩런 BackOffice</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="~/css/readingRunAdmin.css" asp-append-version="true" />
  @await RenderSectionAsync("Styles", required: false)
</head>
<body>
  <aside class="sidebar">
    <div class="sidebar-logo">
      <img src="https://image.yes24.com/sysimage/renew/gnb/logoN4.svg" alt="YES24" />
      <div class="sidebar-logo-text">
        Reading Run
        <span class="sidebar-logo-sub">BackOffice</span>
      </div>
    </div>
    <nav>
      <div class="lnb-section">리딩런</div>
      <a class="lnb-item" asp-controller="ReadingRun" asp-action="Dashboard" data-page="dashboard">
        <i class="bi bi-bar-chart-line lnb-icon"></i>누적 통계 (대시보드)
      </a>
      <a class="lnb-item" asp-controller="ReadingRun" asp-action="CourseStatus" data-page="course-status">
        <i class="bi bi-layers lnb-icon"></i>코스별 현황
      </a>
      <a class="lnb-item" asp-controller="ReadingRun" asp-action="Donation" data-page="donation">
        <i class="bi bi-heart lnb-icon"></i>코스별 기부 현황
      </a>
      <div class="lnb-section">회원관리</div>
      <a class="lnb-item" asp-controller="ReadingRun" asp-action="MemberList" data-page="member-list">
        <i class="bi bi-people lnb-icon"></i>리딩런 회원관리
      </a>
      <div class="lnb-section">리워드관리</div>
      <a class="lnb-item" asp-controller="ReadingRun" asp-action="BadgeList" data-page="badge-list">
        <i class="bi bi-award lnb-icon"></i>배지 관리
      </a>
      <a class="lnb-item" asp-controller="ReadingRun" asp-action="BadgeStats" data-page="badge-stats">
        <i class="bi bi-graph-up lnb-icon"></i>배지 획득 통계
      </a>
      <div class="lnb-section">도서순위</div>
      <a class="lnb-item" asp-controller="ReadingRun" asp-action="BookRanking" data-page="book-ranking">
        <i class="bi bi-book lnb-icon"></i>리딩런 도서순위
      </a>
    </nav>
  </aside>

  <div class="main-wrap">
    @RenderBody()
  </div>

  <script src="~/lib/jquery/dist/jquery.min.js"></script>
  <script src="~/js/common.js" asp-append-version="true"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
