@{
    ViewBag.Title = "리딩런 회원정보";
    ViewBag.Breadcrumb = Html.Raw("리딩런 회원관리 &gt; <a href='/Member' class='text-blue-600 hover:underline'>리딩런 회원관리</a> &gt; <span class='font-semibold text-gray-800'>리딩런 회원정보</span>");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="space-y-5" id="memberDetailPage">
    <!-- 페이지 헤더 -->
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-900">리딩런 회원정보</h1>
        <a href="/Member" class="btn-secondary inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            목록으로
        </a>
    </div>

    <!-- 회원 기본 정보 -->
    <section class="bg-white rounded-lg border border-gray-200 p-5">
        <h2 class="text-sm font-semibold text-gray-500 uppercase mb-4">회원 기본 정보</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="memberBasicInfo">
            <div>
                <div class="text-xs text-gray-500 mb-1">회원 번호</div>
                <div class="font-semibold text-gray-800" id="memberNo">-</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 mb-1">회원 ID</div>
                <div class="font-semibold text-gray-800" id="memberId">-</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 mb-1">현재 코스</div>
                <div id="currentCourse">-</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 mb-1">총 완주 횟수</div>
                <div class="font-semibold text-green-600 text-lg" id="completeCount">-</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 mb-1">총 독서 시간 (분)</div>
                <div class="font-semibold text-blue-600" id="totalReadingTime">-</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 mb-1">누적 거리 (km)</div>
                <div class="font-semibold text-indigo-600" id="totalDistance">-</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 mb-1">마지막 활동일시</div>
                <div class="text-gray-800" id="lastActivityDatetime">-</div>
            </div>
            <div>
                <div class="text-xs text-gray-500 mb-1">이벤트 가입일시</div>
                <div class="text-gray-800" id="registDatetime">-</div>
            </div>
        </div>
    </section>

    <!-- 리워드 정보 -->
    <section class="bg-white rounded-lg border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold text-gray-500 uppercase">리워드 정보</h2>
            <div class="flex gap-2">
                <button type="button" class="btn-secondary text-xs" onclick="openBadgePopup()">
                    배지 획득 리워드 상세
                </button>
                <button type="button" class="btn-secondary text-xs" onclick="openGiftPopup()">
                    상품권 발급 이력 상세
                </button>
            </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <div class="stat-card">
                <div class="text-xs text-gray-500">획득 배지 수</div>
                <div class="text-2xl font-bold text-purple-600" id="badgeCount">-</div>
            </div>
            <div class="stat-card">
                <div class="text-xs text-gray-500">상품권 발급 수</div>
                <div class="text-2xl font-bold text-amber-600" id="giftCount">-</div>
            </div>
        </div>
    </section>

    <!-- 챌린지 참여 상세 정보 -->
    <section class="bg-white rounded-lg border border-gray-200">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-500 uppercase">챌린지 참여 상세 정보</h2>
            <span class="text-sm text-gray-500">총 <span id="resultCountDisplay" class="font-semibold text-gray-800">0</span>건</span>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>코스명</th>
                        <th>코스 회차</th>
                        <th>결과 상태</th>
                        <th>코스 시작일시</th>
                        <th>완주 여부</th>
                        <th>완주 일시</th>
                        <th>증서 발급</th>
                        <th>배지 지급</th>
                        <th>상품권 지급</th>
                        <th>기부 적용</th>
                        <th>세션 상세</th>
                    </tr>
                </thead>
                <tbody id="resultTableBody">
                    <tr><td colspan="12" class="py-8 text-gray-400">불러오는 중...</td></tr>
                </tbody>
            </table>
        </div>
        <div class="px-5 pb-4" id="resultPagination"></div>
    </section>

    <!-- 독서 활동 (세션) -->
    <section class="bg-white rounded-lg border border-gray-200">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-500 uppercase">독서 활동 (세션)</h2>
            <span class="text-sm text-gray-500">총 <span id="activityCountDisplay" class="font-semibold text-gray-800">0</span>건</span>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>활동일</th>
                        <th>코스명</th>
                        <th>세션 상태</th>
                        <th>시작 일시</th>
                        <th>종료 일시</th>
                        <th>독서 시간 (분)</th>
                        <th>거리 (km)</th>
                        <th>도서 상품번호</th>
                        <th>세션 상세</th>
                    </tr>
                </thead>
                <tbody id="activityTableBody">
                    <tr><td colspan="10" class="py-8 text-gray-400">불러오는 중...</td></tr>
                </tbody>
            </table>
        </div>
        <div class="px-5 pb-4" id="activityPagination"></div>
    </section>
</div>

<!-- 배지 획득 리워드 상세 팝업 -->
<div id="badgeModal" class="fixed inset-0 z-50 hidden flex items-center justify-center" style="background:rgba(0,0,0,0.5)">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-xl max-h-[80vh] flex flex-col">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
            <h3 class="text-base font-bold text-gray-900">배지 획득 리워드 상세</h3>
            <button type="button" onclick="$('#badgeModal').addClass('hidden')" class="text-gray-400 hover:text-gray-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto p-4">
            <table class="data-table">
                <thead><tr><th>번호</th><th>배지 ID</th><th>배지명</th><th>획득 일시</th></tr></thead>
                <tbody id="badgeListBody"><tr><td colspan="4" class="py-6 text-gray-400">불러오는 중...</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

<!-- 상품권 발급 이력 상세 팝업 -->
<div id="giftModal" class="fixed inset-0 z-50 hidden flex items-center justify-center" style="background:rgba(0,0,0,0.5)">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-xl max-h-[80vh] flex flex-col">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
            <h3 class="text-base font-bold text-gray-900">상품권 발급 이력 상세</h3>
            <button type="button" onclick="$('#giftModal').addClass('hidden')" class="text-gray-400 hover:text-gray-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto p-4">
            <table class="data-table">
                <thead><tr><th>번호</th><th>상품권 ID</th><th>상품권명</th><th>발급 일시</th></tr></thead>
                <tbody id="giftListBody"><tr><td colspan="4" class="py-6 text-gray-400">불러오는 중...</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

<!-- 세션 상세 정보 팝업 -->
<div id="sessionModal" class="fixed inset-0 z-50 hidden flex items-center justify-center" style="background:rgba(0,0,0,0.5)">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-4xl max-h-[85vh] flex flex-col">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
            <div>
                <h3 class="text-base font-bold text-gray-900">세션 상세 정보</h3>
                <p class="text-xs text-gray-500 mt-0.5">활동일 : <span id="sessionActivityDate" class="font-medium">-</span></p>
            </div>
            <button type="button" onclick="$('#sessionModal').addClass('hidden')" class="text-gray-400 hover:text-gray-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto p-4">
            <div class="overflow-x-auto">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>번호</th>
                            <th>시작 시간</th>
                            <th>종료 시간</th>
                            <th>독서 시간</th>
                            <th>환산 거리</th>
                            <th>세션 상태</th>
                            <th>도서명</th>
                            <th>도서 상품ID</th>
                        </tr>
                    </thead>
                    <tbody id="sessionDetailBody"><tr><td colspan="8" class="py-6 text-gray-400">불러오는 중...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var memberNo = @(ViewBag.MemberNo ?? 0);
var eventNo  = @(ViewBag.EventNo  ?? 0);

$(function () {
    loadMemberDetail();
    loadResultList(1);
    loadActivityList(1);
});

function loadMemberDetail() {
    $.getJSON('/api/Member/Detail', { Member_No: memberNo, Event_No: eventNo }, function (data) {
        $('#memberNo').text(data.Member_No || '-');
        $('#memberId').text(data.Member_Id || data.Member_No || '-');
        $('#currentCourse').html(courseLabel(data.Current_Course));
        $('#completeCount').text(BO.numFormat(data.Complete_Count));
        $('#totalReadingTime').text(BO.numFormat(data.Total_Reading_Time));
        $('#totalDistance').text(data.Total_Distance ? parseFloat(data.Total_Distance).toFixed(2) : '0.00');
        $('#lastActivityDatetime').text(BO.dateFormat(data.Last_Activity_Datetime));
        $('#registDatetime').text(BO.dateFormat(data.Regist_Datetime));
        $('#badgeCount').text(BO.numFormat(data.Badge_Count));
        $('#giftCount').text(BO.numFormat(data.Gift_Count));
    });
}

function loadResultList(page) {
    $.getJSON('/api/Member/ResultList', { Member_No: memberNo, Event_No: eventNo, page: page, pageSize: 20 }, function (res) {
        $('#resultCountDisplay').text((res.TotalCount || 0).toLocaleString());
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="12" class="py-6 text-gray-400">참여 기록이 없습니다.</td></tr>';
        } else {
            var sn = (res.TotalCount || 0) - ((page-1)*20);
            $.each(res.List, function (i, d) {
                rows += '<tr>' +
                    '<td>' + (sn - i) + '</td>' +
                    '<td>' + courseLabel(d.Course_Name) + '</td>' +
                    '<td>' + BO.numFormat(d.Course_Round_No) + '</td>' +
                    '<td>' + (d.Result_Status_Code || '-') + '</td>' +
                    '<td>' + BO.dateFormat(d.Course_Start_Datetime) + '</td>' +
                    '<td>' + (d.Complete_Yn ? '<span class="badge-green">완주</span>' : '<span class="badge-gray">미완주</span>') + '</td>' +
                    '<td>' + (d.Complete_Yn && d.Complete_Datetime ? BO.dateFormat(d.Complete_Datetime) : '-') + '</td>' +
                    '<td>' + ynBadge(d.Certificate_Create_Yn) + '</td>' +
                    '<td>' + ynBadge(d.Badge_Reward_Yn) + '</td>' +
                    '<td>' + ynBadge(d.Gift_Reward_Yn) + '</td>' +
                    '<td>' + ynBadge(d.Donation_Apply_Yn) + '</td>' +
                    '<td><button type="button" class="text-blue-600 hover:underline text-xs" onclick="openSessionModal(\'' + d.Activity_Date + '\')">세션 보기</button></td>' +
                    '</tr>';
            });
        }
        $('#resultTableBody').html(rows);
        renderPagination(res.TotalCount || 0, page, '#resultPagination', loadResultList);
    });
}

function loadActivityList(page) {
    $.getJSON('/api/Member/ActivityList', { Member_No: memberNo, Event_No: eventNo, page: page, pageSize: 20 }, function (res) {
        $('#activityCountDisplay').text((res.TotalCount || 0).toLocaleString());
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="10" class="py-6 text-gray-400">활동 기록이 없습니다.</td></tr>';
        } else {
            var sn = (res.TotalCount || 0) - ((page-1)*20);
            $.each(res.List, function (i, d) {
                rows += '<tr>' +
                    '<td>' + (sn - i) + '</td>' +
                    '<td>' + (d.Activity_Date || '-') + '</td>' +
                    '<td>' + courseLabel(d.Course_Name) + '</td>' +
                    '<td>' + (d.Session_Status || '-') + '</td>' +
                    '<td>' + BO.dateFormat(d.Session_Start_Datetime) + '</td>' +
                    '<td>' + (d.Session_End_Datetime ? BO.dateFormat(d.Session_End_Datetime) : '-') + '</td>' +
                    '<td>' + BO.numFormat(d.Reading_Time) + '</td>' +
                    '<td>' + (d.Distance ? parseFloat(d.Distance).toFixed(2) : '-') + '</td>' +
                    '<td>' + (d.Goods_No || '-') + '</td>' +
                    '<td><button type="button" class="text-blue-600 hover:underline text-xs" onclick="openSessionModal(\'' + d.Activity_Date + '\')">상세 보기</button></td>' +
                    '</tr>';
            });
        }
        $('#activityTableBody').html(rows);
        renderPagination(res.TotalCount || 0, page, '#activityPagination', loadActivityList);
    });
}

function openSessionModal(activityDate) {
    $('#sessionActivityDate').text(activityDate || '-');
    $('#sessionModal').removeClass('hidden');
    $('#sessionDetailBody').html('<tr><td colspan="8" class="py-6 text-gray-400">불러오는 중...</td></tr>');
    $.getJSON('/api/Member/SessionDetail', { Member_No: memberNo, Event_No: eventNo, Activity_Date: activityDate }, function (res) {
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="8" class="py-6 text-gray-400">세션 정보가 없습니다.</td></tr>';
        } else {
            $.each(res.List, function (i, d) {
                rows += '<tr>' +
                    '<td>' + (i + 1) + '</td>' +
                    '<td>' + BO.dateFormat(d.Session_Start_Datetime) + '</td>' +
                    '<td>' + (d.Session_End_Datetime ? BO.dateFormat(d.Session_End_Datetime) : '-') + '</td>' +
                    '<td>' + BO.numFormat(d.Reading_Time) + ' 분</td>' +
                    '<td>' + (d.Distance ? parseFloat(d.Distance).toFixed(2) + ' km' : '-') + '</td>' +
                    '<td>' + (d.Session_Status || '-') + '</td>' +
                    '<td>' + (d.Book_Name || '-') + '</td>' +
                    '<td>' + (d.Goods_No || '-') + '</td>' +
                    '</tr>';
            });
        }
        $('#sessionDetailBody').html(rows);
    });
}

function openBadgePopup() {
    $('#badgeModal').removeClass('hidden');
    $('#badgeListBody').html('<tr><td colspan="4" class="py-6 text-gray-400">불러오는 중...</td></tr>');
    $.getJSON('/api/Member/BadgeList', { Member_No: memberNo, Event_No: eventNo }, function (res) {
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="4" class="py-6 text-gray-400">획득한 배지가 없습니다.</td></tr>';
        } else {
            $.each(res.List, function (i, d) {
                rows += '<tr><td>' + (i+1) + '</td><td>' + (d.Reward_Code || '-') + '</td><td class="text-left">' + (d.Reward_Name || '-') + '</td><td>' + BO.dateFormat(d.Regist_Datetime) + '</td></tr>';
            });
        }
        $('#badgeListBody').html(rows);
    });
}

function openGiftPopup() {
    $('#giftModal').removeClass('hidden');
    $('#giftListBody').html('<tr><td colspan="4" class="py-6 text-gray-400">불러오는 중...</td></tr>');
    $.getJSON('/api/Member/GiftList', { Member_No: memberNo, Event_No: eventNo }, function (res) {
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="4" class="py-6 text-gray-400">발급된 상품권이 없습니다.</td></tr>';
        } else {
            $.each(res.List, function (i, d) {
                rows += '<tr><td>' + (i+1) + '</td><td>' + (d.Reward_Code || '-') + '</td><td class="text-left">' + (d.Reward_Name || '-') + '</td><td>' + BO.dateFormat(d.Regist_Datetime) + '</td></tr>';
            });
        }
        $('#giftListBody').html(rows);
    });
}

function courseLabel(name) {
    var map = { 'Starter': '<span class="badge-blue">스타터</span>', 'Half': '<span class="badge-green">하프</span>', 'Marathon': '<span class="badge-yellow">마라톤</span>' };
    return map[name] || (name || '-');
}

function ynBadge(val) {
    return val ? '<span class="badge-green">Y</span>' : '<span class="badge-gray">N</span>';
}

function renderPagination(totalCount, currentPage, containerId, callback) {
    var pageSize = 20, totalPages = Math.ceil(totalCount / pageSize);
    var html = '<div class="flex items-center justify-between mt-3 flex-wrap gap-2">' +
        '<div class="text-sm text-gray-500">총 <span class="font-semibold">' + totalCount.toLocaleString() + '</span>건 | ' + currentPage + ' / ' + (totalPages || 1) + '</div>';
    if (totalPages > 1) {
        html += '<nav class="flex items-center gap-1 text-sm">';
        var blockSize = 10, blockStart = Math.floor((currentPage-1)/blockSize)*blockSize+1, blockEnd = Math.min(blockStart+blockSize-1, totalPages);
        if (blockStart > 1) { html += '<a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="1">&laquo;</a><a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="'+(blockStart-1)+'">&lt;</a>'; }
        for (var p = blockStart; p <= blockEnd; p++) {
            if (p === currentPage) html += '<span class="px-3 py-1 rounded border border-blue-500 bg-blue-500 text-white font-semibold">'+p+'</span>';
            else html += '<a href="#" class="pag-btn px-3 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="'+p+'">'+p+'</a>';
        }
        if (blockEnd < totalPages) { html += '<a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="'+(blockEnd+1)+'">&gt;</a><a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="'+totalPages+'">&raquo;</a>'; }
        html += '</nav>';
    }
    html += '</div>';
    $(containerId).html(html);
    $(containerId).off('click', '.pag-btn').on('click', '.pag-btn', function(e){ e.preventDefault(); callback(parseInt($(this).data('page'))); });
}
</script>
}
