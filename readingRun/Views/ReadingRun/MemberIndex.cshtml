@{
    ViewBag.Title = "리딩런 회원관리";
    ViewBag.Breadcrumb = Html.Raw("리딩런 회원관리 &gt; <span class='font-semibold text-gray-800'>리딩런 회원관리</span>");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="space-y-4" id="memberIndexPage">
    <!-- 페이지 헤더 -->
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-900">리딩런 회원관리</h1>
    </div>

    <!-- 검색 영역 -->
    <div class="search-box">
        <div class="flex flex-wrap gap-3 items-end">
            <!-- 검색 조건 선택 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">검색 조건</label>
                <div class="flex gap-1">
                    <select id="searchField" class="form-select w-32">
                        <option value="Member_Id">회원 ID</option>
                        <option value="Member_No">회원 번호</option>
                    </select>
                    <input type="text" id="searchKeyword" class="form-input w-44" placeholder="검색어 입력" />
                </div>
            </div>
            <!-- 현재 코스 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">현재 코스</label>
                <select id="searchCourse" class="form-select w-32">
                    <option value="">전체</option>
                    <option value="Starter">스타터</option>
                    <option value="Half">하프</option>
                    <option value="Marathon">마라톤</option>
                </select>
            </div>
            <!-- 가입 기간 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">가입일</label>
                <div class="flex items-center gap-1">
                    <input type="date" id="searchStartDate" class="form-input w-36" />
                    <span class="text-gray-400 text-sm">~</span>
                    <input type="date" id="searchEndDate" class="form-input w-36" />
                </div>
            </div>
            <div class="flex gap-2 items-end">
                <button type="button" id="btnSearch" class="btn-primary">검색</button>
                <button type="button" id="btnReset" class="btn-secondary">초기화</button>
                <button type="button" id="btnExcel" class="inline-flex items-center gap-1 bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded text-sm font-medium transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    엑셀 다운로드
                </button>
            </div>
        </div>
    </div>

    <!-- 조회 결과 -->
    <div class="bg-white rounded-lg border border-gray-200">
        <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
            <span class="text-sm text-gray-600">
                총 <span id="totalCountDisplay" class="font-semibold text-gray-800">0</span>건
            </span>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>회원 ID</th>
                        <th>현재 코스</th>
                        <th>총 독서 시간 (분)</th>
                        <th>누적 거리 (km)</th>
                        <th>완주 횟수</th>
                        <th>마지막 활동일시</th>
                        <th>가입일시</th>
                    </tr>
                </thead>
                <tbody id="memberTableBody">
                    <tr><td colspan="8" class="py-8 text-gray-400">검색 조건을 입력하고 검색 버튼을 클릭하세요.</td></tr>
                </tbody>
            </table>
        </div>
        <div class="px-4 pb-4" id="memberPagination"></div>
    </div>
</div>

@section Scripts {
<script>
$(function () {
    loadMemberList(1);

    $('#btnSearch').on('click', function () { loadMemberList(1); });
    $('#btnReset').on('click', function () {
        $('#searchKeyword').val('');
        $('#searchCourse').val('');
        $('#searchStartDate, #searchEndDate').val('');
        loadMemberList(1);
    });
    $('#btnExcel').on('click', function () {
        var params = getSearchParams();
        params.excel = 1;
        window.location.href = '/api/Member/List/Excel?' + $.param(params);
    });
    $('#searchKeyword').on('keydown', function (e) {
        if (e.key === 'Enter') loadMemberList(1);
    });
});

function getSearchParams() {
    var field = $('#searchField').val();
    var params = { Current_Course: $('#searchCourse').val(), Start_Date: $('#searchStartDate').val(), End_Date: $('#searchEndDate').val() };
    params[field] = $('#searchKeyword').val();
    return params;
}

function loadMemberList(page) {
    var params = getSearchParams();
    params.page = page;
    params.pageSize = 20;

    $('#memberTableBody').html('<tr><td colspan="8" class="py-8 text-gray-400">불러오는 중...</td></tr>');

    $.getJSON('/api/Member/List', params, function (res) {
        $('#totalCountDisplay').text((res.TotalCount || 0).toLocaleString());
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="8" class="py-8 text-gray-400">조회된 데이터가 없습니다.</td></tr>';
        } else {
            var startNo = (res.TotalCount || 0) - ((page - 1) * 20);
            $.each(res.List, function (i, d) {
                var courseBadge = courseLabel(d.Current_Course);
                rows += '<tr>' +
                    '<td>' + (startNo - i) + '</td>' +
                    '<td class="text-left"><a href="/Member/Detail/' + d.Member_No + '?Event_No=' + (d.Event_No || 0) + '" class="text-blue-600 hover:underline font-medium">' + (d.Member_Id || d.Member_No) + '</a></td>' +
                    '<td>' + courseBadge + '</td>' +
                    '<td>' + BO.numFormat(d.Total_Reading_Time) + '</td>' +
                    '<td>' + (d.Total_Distance ? parseFloat(d.Total_Distance).toFixed(2) : '0.00') + '</td>' +
                    '<td>' + BO.numFormat(d.Complete_Count) + '</td>' +
                    '<td>' + BO.dateFormat(d.Last_Activity_Datetime) + '</td>' +
                    '<td>' + BO.dateFormat(d.Regist_Datetime) + '</td>' +
                    '</tr>';
            });
        }
        $('#memberTableBody').html(rows);
        renderPagination(res.TotalCount || 0, page, '#memberPagination', loadMemberList);
    });
}

function courseLabel(name) {
    var map = { 'Starter': '<span class="badge-blue">스타터</span>', 'Half': '<span class="badge-green">하프</span>', 'Marathon': '<span class="badge-yellow">마라톤</span>' };
    return map[name] || (name || '-');
}

function renderPagination(totalCount, currentPage, containerId, callback) {
    var pageSize = 20, totalPages = Math.ceil(totalCount / pageSize);
    var html = '<div class="flex items-center justify-between mt-3 flex-wrap gap-2">' +
        '<div class="text-sm text-gray-500">총 <span class="font-semibold text-gray-700">' + totalCount.toLocaleString() + '</span>건 | 현재 페이지 : <span class="font-semibold">' + currentPage + ' / ' + (totalPages || 1) + '</span></div>';
    if (totalPages > 1) {
        html += '<nav class="flex items-center gap-1 text-sm">';
        var blockSize = 10, blockStart = Math.floor((currentPage-1)/blockSize)*blockSize+1, blockEnd = Math.min(blockStart+blockSize-1, totalPages);
        if (blockStart > 1) { html += '<a href="#" class="pag-btn px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="1">&laquo;</a><a href="#" class="pag-btn px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="'+(blockStart-1)+'">&lt;</a>'; }
        for (var p = blockStart; p <= blockEnd; p++) {
            if (p === currentPage) html += '<span class="px-3 py-1 rounded border border-blue-500 bg-blue-500 text-white font-semibold">'+p+'</span>';
            else html += '<a href="#" class="pag-btn px-3 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="'+p+'">'+p+'</a>';
        }
        if (blockEnd < totalPages) { html += '<a href="#" class="pag-btn px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="'+(blockEnd+1)+'">&gt;</a><a href="#" class="pag-btn px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="'+totalPages+'">&raquo;</a>'; }
        html += '</nav>';
    }
    html += '</div>';
    $(containerId).html(html);
    $(containerId).off('click', '.pag-btn').on('click', '.pag-btn', function(e){ e.preventDefault(); callback(parseInt($(this).data('page'))); });
}
</script>
}
