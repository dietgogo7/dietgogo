@{
    ViewBag.Title = "리딩런 도서순위";
    ViewBag.Breadcrumb = Html.Raw("리딩런 도서순위 &gt; <span class='font-semibold text-gray-800'>리딩런 도서순위</span>");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="space-y-4" id="bookRankingPage">
    <!-- 페이지 헤더 -->
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-900">리딩런 도서순위</h1>
        <div class="text-sm text-gray-500">
            정보 업데이트일 : <span id="updateDatetime" class="font-medium">-</span> 기준
        </div>
    </div>

    <!-- 검색 영역 -->
    <div class="search-box">
        <div class="flex flex-wrap gap-3 items-end">
            <!-- 기준일 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">기준일</label>
                <input type="date" id="searchStandardDate" class="form-input w-36" />
            </div>
            <!-- 코스 필터 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">코스</label>
                <select id="searchCourse" class="form-select w-32">
                    <option value="">전체</option>
                    <option value="Starter">스타터</option>
                    <option value="Half">하프</option>
                    <option value="Marathon">마라톤</option>
                </select>
            </div>
            <!-- 도서명/상품번호 검색 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">도서명 / 상품번호</label>
                <input type="text" id="searchKeyword" class="form-input w-48" placeholder="도서명 또는 상품번호 입력" />
            </div>
            <div class="flex gap-2 items-end">
                <button type="button" id="btnSearch" class="btn-primary">검색</button>
                <button type="button" id="btnReset" class="btn-secondary">초기화</button>
                <button type="button" id="btnExcel" class="inline-flex items-center gap-1 bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded text-sm font-medium transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    엑셀 다운로드
                </button>
            </div>
        </div>
    </div>

    <!-- 순위 안내 -->
    <div class="flex items-start gap-2 text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3">
        <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>도서 선택 횟수가 많은 순서대로 순위가 표시됩니다 (1~100위). 선택 횟수가 동일한 경우 등록일시가 이른 도서가 높은 순위로 표시됩니다.</span>
    </div>

    <!-- 순위 테이블 -->
    <div class="bg-white rounded-lg border border-gray-200">
        <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
            <span class="text-sm text-gray-600">
                총 <span id="totalCountDisplay" class="font-semibold text-gray-800">0</span>건
            </span>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th class="w-16">순위</th>
                        <th>도서 상품번호 (Goods_No)</th>
                        <th>도서명</th>
                        <th>코스</th>
                        <th>선택 횟수</th>
                        <th>기준일</th>
                    </tr>
                </thead>
                <tbody id="rankingTableBody">
                    <tr><td colspan="6" class="py-8 text-gray-400">검색 조건을 입력하고 검색 버튼을 클릭하세요.</td></tr>
                </tbody>
            </table>
        </div>
        <div class="px-4 pb-4" id="rankingPagination"></div>
    </div>
</div>

@section Scripts {
<script>
var rankingCurrentPage = 1;
var defaultEventNo = @(ViewBag.EventNo ?? 0);

$(function () {
    // 오늘 날짜를 기본값으로
    var today = new Date().toISOString().split('T')[0];
    $('#searchStandardDate').val(today);

    loadRankingList(1);

    $('#btnSearch').on('click', function () { loadRankingList(1); });
    $('#btnReset').on('click', function () {
        $('#searchStandardDate').val(today);
        $('#searchCourse').val('');
        $('#searchKeyword').val('');
        loadRankingList(1);
    });
    $('#btnExcel').on('click', function () {
        var params = getSearchParams();
        params.excel = 1;
        window.location.href = '/api/Record/BookRanking/Excel?' + $.param(params);
    });
    $('#searchKeyword').on('keydown', function (e) {
        if (e.key === 'Enter') loadRankingList(1);
    });
});

function getSearchParams() {
    return {
        Event_No:       defaultEventNo,
        Standard_Date:  $('#searchStandardDate').val(),
        Course_Name:    $('#searchCourse').val(),
        Keyword:        $('#searchKeyword').val()
    };
}

function loadRankingList(page) {
    rankingCurrentPage = page;
    var params = getSearchParams();
    params.page = page;
    params.pageSize = 20;

    $('#rankingTableBody').html('<tr><td colspan="6" class="py-8 text-gray-400">불러오는 중...</td></tr>');

    $.getJSON('/api/Record/BookRanking', params, function (res) {
        $('#updateDatetime').text(BO.dateFormat(res.UpdateDatetime));
        $('#totalCountDisplay').text((res.TotalCount || 0).toLocaleString());
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="6" class="py-8 text-gray-400">조회된 데이터가 없습니다.</td></tr>';
        } else {
            $.each(res.List, function (i, d) {
                var rankDisplay = '';
                var rankNo = d.Ranking || ((page - 1) * 20 + i + 1);
                if (rankNo === 1) rankDisplay = '<span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-yellow-400 text-white font-bold text-sm">1</span>';
                else if (rankNo === 2) rankDisplay = '<span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-300 text-white font-bold text-sm">2</span>';
                else if (rankNo === 3) rankDisplay = '<span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-amber-600 text-white font-bold text-sm">3</span>';
                else rankDisplay = '<span class="font-semibold text-gray-700">' + rankNo + '</span>';

                rows += '<tr>' +
                    '<td>' + rankDisplay + '</td>' +
                    '<td class="font-mono text-sm">' + (d.Goods_No || '-') + '</td>' +
                    '<td class="text-left font-medium text-gray-900">' + (d.Book_Name || '-') + '</td>' +
                    '<td>' + courseLabel(d.Course_Name) + '</td>' +
                    '<td class="font-semibold text-blue-600">' + BO.numFormat(d.Select_Count) + '</td>' +
                    '<td>' + (d.Standard_Date || '-') + '</td>' +
                    '</tr>';
            });
        }
        $('#rankingTableBody').html(rows);
        renderPagination(res.TotalCount || 0, page, '#rankingPagination', loadRankingList);
    });
}

function courseLabel(name) {
    var map = { 'Starter': '<span class="badge-blue">스타터</span>', 'Half': '<span class="badge-green">하프</span>', 'Marathon': '<span class="badge-yellow">마라톤</span>' };
    return map[name] || (name || '-');
}

function renderPagination(totalCount, currentPage, containerId, callback) {
    var pageSize = 20, totalPages = Math.ceil(totalCount / pageSize);
    var html = '<div class="flex items-center justify-between mt-3 flex-wrap gap-2">' +
        '<div class="text-sm text-gray-500">총 <span class="font-semibold text-gray-700">' + totalCount.toLocaleString() + '</span>건 | 현재 페이지 : <span class="font-semibold">' + currentPage + ' / ' + (totalPages||1) + '</span></div>';
    if (totalPages > 1) {
        html += '<nav class="flex items-center gap-1 text-sm">';
        var blockSize = 10, blockStart = Math.floor((currentPage-1)/blockSize)*blockSize+1, blockEnd = Math.min(blockStart+blockSize-1, totalPages);
        if (blockStart > 1) { html += '<a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="1">&laquo;</a><a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="'+(blockStart-1)+'">&lt;</a>'; }
        for (var p = blockStart; p <= blockEnd; p++) {
            if (p === currentPage) html += '<span class="px-3 py-1 rounded border border-blue-500 bg-blue-500 text-white font-semibold">'+p+'</span>';
            else html += '<a href="#" class="pag-btn px-3 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="'+p+'">'+p+'</a>';
        }
        if (blockEnd < totalPages) { html += '<a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="'+(blockEnd+1)+'">&gt;</a><a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="'+totalPages+'">&raquo;</a>'; }
        html += '</nav>';
    }
    html += '</div>';
    $(containerId).html(html);
    $(containerId).off('click', '.pag-btn').on('click', '.pag-btn', function(e){ e.preventDefault(); callback(parseInt($(this).data('page'))); });
}
</script>
}
