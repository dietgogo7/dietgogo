@{
    ViewBag.Title = "리딩런 누적 통계";
    ViewBag.Breadcrumb = Html.Raw("리딩런 &gt; <span class='font-semibold text-gray-800'>누적 통계 (대시보드)</span>");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="space-y-5" id="dashboardPage">
    <!-- 페이지 헤더 -->
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-900">리딩런 누적 통계 (대시보드)</h1>
        <div class="text-sm text-gray-500">
            <span class="inline-flex items-center gap-1 bg-amber-50 border border-amber-200 text-amber-700 px-3 py-1 rounded-full">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                캠페인 시작일 : <strong id="campaignStartDate">-</strong>
            </span>
            &nbsp;
            정보 업데이트일 : <span id="updateDatetime" class="font-medium">-</span> 기준
        </div>
    </div>

    <!-- 전체 누적 통계 -->
    <section>
        <h2 class="text-sm font-semibold text-gray-500 uppercase mb-3">전체 누적</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4" id="totalStats">
            <div class="stat-card">
                <div class="text-xs text-gray-500">참여자 누적</div>
                <div class="text-2xl font-bold text-blue-600" id="totalParticipant">-</div>
                <div class="text-xs text-gray-400">명</div>
            </div>
            <div class="stat-card">
                <div class="text-xs text-gray-500">세션 누적</div>
                <div class="text-2xl font-bold text-indigo-600" id="totalSession">-</div>
                <div class="text-xs text-gray-400">회</div>
            </div>
            <div class="stat-card">
                <div class="text-xs text-gray-500">누적 독서 시간</div>
                <div class="text-2xl font-bold text-purple-600" id="totalReadingTime">-</div>
                <div class="text-xs text-gray-400">분</div>
            </div>
            <div class="stat-card">
                <div class="text-xs text-gray-500">누적 완주 횟수</div>
                <div class="text-2xl font-bold text-green-600" id="totalComplete">-</div>
                <div class="text-xs text-gray-400">회</div>
            </div>
            <div class="stat-card">
                <div class="text-xs text-gray-500">누적 기부 거리</div>
                <div class="text-2xl font-bold text-rose-600" id="totalDonation">-</div>
                <div class="text-xs text-gray-400">km</div>
            </div>
        </div>
    </section>

    <!-- 코스별 현황 -->
    <section>
        <h2 class="text-sm font-semibold text-gray-500 uppercase mb-3">코스별 현황</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5" id="courseStats">
            <!-- Starter -->
            <div class="bg-white rounded-lg border border-blue-200 overflow-hidden">
                <div class="bg-blue-50 border-b border-blue-200 px-4 py-3">
                    <div class="flex items-center gap-2">
                        <span class="badge-blue">스타터</span>
                        <span class="text-sm font-semibold text-blue-800">Starter Course</span>
                    </div>
                </div>
                <div class="p-4 grid grid-cols-2 gap-3">
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">참여 횟수</div>
                        <div class="text-xl font-bold text-gray-800" id="starterJoin">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">완주 횟수</div>
                        <div class="text-xl font-bold text-green-600" id="starterComplete">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">완주율</div>
                        <div class="text-xl font-bold text-indigo-600" id="starterCompleteRate">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">잔여 완주 필요</div>
                        <div class="text-xl font-bold text-amber-600" id="starterRemain">-</div>
                    </div>
                    <div class="col-span-2 text-center border-t border-gray-100 pt-3">
                        <div class="text-xs text-gray-500 mb-1">기부 금액</div>
                        <div class="text-xl font-bold text-rose-600" id="starterDonation">-</div>
                        <div class="text-xs text-gray-400">원</div>
                    </div>
                </div>
            </div>
            <!-- Half -->
            <div class="bg-white rounded-lg border border-green-200 overflow-hidden">
                <div class="bg-green-50 border-b border-green-200 px-4 py-3">
                    <div class="flex items-center gap-2">
                        <span class="badge-green">하프</span>
                        <span class="text-sm font-semibold text-green-800">Half Course</span>
                    </div>
                </div>
                <div class="p-4 grid grid-cols-2 gap-3">
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">참여 횟수</div>
                        <div class="text-xl font-bold text-gray-800" id="halfJoin">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">완주 횟수</div>
                        <div class="text-xl font-bold text-green-600" id="halfComplete">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">완주율</div>
                        <div class="text-xl font-bold text-indigo-600" id="halfCompleteRate">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">잔여 완주 필요</div>
                        <div class="text-xl font-bold text-amber-600" id="halfRemain">-</div>
                    </div>
                    <div class="col-span-2 text-center border-t border-gray-100 pt-3">
                        <div class="text-xs text-gray-500 mb-1">기부 금액</div>
                        <div class="text-xl font-bold text-rose-600" id="halfDonation">-</div>
                        <div class="text-xs text-gray-400">원</div>
                    </div>
                </div>
            </div>
            <!-- Marathon -->
            <div class="bg-white rounded-lg border border-orange-200 overflow-hidden">
                <div class="bg-orange-50 border-b border-orange-200 px-4 py-3">
                    <div class="flex items-center gap-2">
                        <span class="badge-yellow">마라톤</span>
                        <span class="text-sm font-semibold text-orange-800">Marathon Course</span>
                    </div>
                </div>
                <div class="p-4 grid grid-cols-2 gap-3">
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">참여 횟수</div>
                        <div class="text-xl font-bold text-gray-800" id="marathonJoin">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">완주 횟수</div>
                        <div class="text-xl font-bold text-green-600" id="marathonComplete">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">완주율</div>
                        <div class="text-xl font-bold text-indigo-600" id="marathonCompleteRate">-</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-gray-500 mb-1">잔여 완주 필요</div>
                        <div class="text-xl font-bold text-amber-600" id="marathonRemain">-</div>
                    </div>
                    <div class="col-span-2 text-center border-t border-gray-100 pt-3">
                        <div class="text-xs text-gray-500 mb-1">기부 금액</div>
                        <div class="text-xl font-bold text-rose-600" id="marathonDonation">-</div>
                        <div class="text-xs text-gray-400">원</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 일별 현황 테이블 -->
    <section>
        <h2 class="text-sm font-semibold text-gray-500 uppercase mb-3">일별 현황</h2>
        <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>기준일</th>
                        <th>참여자</th>
                        <th>기부 금액(총)</th>
                        <th>완주(총)</th>
                        <th>스타터 참여</th>
                        <th>스타터 완주</th>
                        <th>하프 참여</th>
                        <th>하프 완주</th>
                        <th>마라톤 참여</th>
                        <th>마라톤 완주</th>
                    </tr>
                </thead>
                <tbody id="dailyTableBody">
                    <tr><td colspan="10" class="py-8 text-gray-400">데이터를 불러오는 중...</td></tr>
                </tbody>
            </table>
        </div>
        <div id="dailyPagination"></div>
    </section>
</div>

@section Scripts {
<script>
$(function () {
    loadDashboard();
    loadDailyList(1);
});

function loadDashboard() {
    $.getJSON('/api/ReadingRun/Dashboard', function (data) {
        // 이벤트 기본 정보
        $('#campaignStartDate').text(data.Campaign_Start_Date || '-');
        $('#updateDatetime').text(BO.dateFormat(data.Update_Datetime));

        // 전체 누적
        $('#totalParticipant').text(BO.numFormat(data.Total_Participant_Count));
        $('#totalSession').text(BO.numFormat(data.Total_Session_Count));
        $('#totalReadingTime').text(BO.numFormat(data.Total_Reading_Time));
        $('#totalComplete').text(BO.numFormat(data.Total_Complete_Times));
        $('#totalDonation').text(BO.numFormat(data.Total_Donation_Amount));

        // 스타터
        $('#starterJoin').text(BO.numFormat(data.Starter_Join_Times));
        $('#starterComplete').text(BO.numFormat(data.Starter_Complete_Times));
        $('#starterCompleteRate').text(calcRate(data.Starter_Complete_Times, data.Starter_Join_Times) + '%');
        $('#starterRemain').text(BO.numFormat(data.Starter_Remain_Complete_Count));
        $('#starterDonation').text(BO.numFormat(data.Starter_Donation_Amount));

        // 하프
        $('#halfJoin').text(BO.numFormat(data.Half_Join_Times));
        $('#halfComplete').text(BO.numFormat(data.Half_Complete_Times));
        $('#halfCompleteRate').text(calcRate(data.Half_Complete_Times, data.Half_Join_Times) + '%');
        $('#halfRemain').text(BO.numFormat(data.Half_Remain_Complete_Count));
        $('#halfDonation').text(BO.numFormat(data.Half_Donation_Amount));

        // 마라톤
        $('#marathonJoin').text(BO.numFormat(data.Marathon_Join_Times));
        $('#marathonComplete').text(BO.numFormat(data.Marathon_Complete_Times));
        $('#marathonCompleteRate').text(calcRate(data.Marathon_Complete_Times, data.Marathon_Join_Times) + '%');
        $('#marathonRemain').text(BO.numFormat(data.Marathon_Remain_Complete_Count));
        $('#marathonDonation').text(BO.numFormat(data.Marathon_Donation_Amount));
    });
}

function calcRate(complete, join) {
    if (!join || join === 0) return '0.0';
    return ((complete / join) * 100).toFixed(1);
}

var dailyCurrentPage = 1;

function loadDailyList(page) {
    dailyCurrentPage = page;
    $.getJSON('/api/ReadingRun/DailySummary', { page: page, pageSize: 20 }, function (res) {
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="10" class="py-8 text-gray-400">조회된 데이터가 없습니다.</td></tr>';
        } else {
            $.each(res.List, function (i, d) {
                rows += '<tr>' +
                    '<td>' + (d.Standard_Date || '-') + '</td>' +
                    '<td>' + BO.numFormat(d.Total_Participant_Count) + '</td>' +
                    '<td>' + BO.numFormat(d.Total_Donation_Amount) + '</td>' +
                    '<td>' + BO.numFormat(d.Total_Complete_Times) + '</td>' +
                    '<td>' + BO.numFormat(d.Starter_Join_Times) + '</td>' +
                    '<td>' + BO.numFormat(d.Starter_Complete_Times) + '</td>' +
                    '<td>' + BO.numFormat(d.Half_Join_Times) + '</td>' +
                    '<td>' + BO.numFormat(d.Half_Complete_Times) + '</td>' +
                    '<td>' + BO.numFormat(d.Marathon_Join_Times) + '</td>' +
                    '<td>' + BO.numFormat(d.Marathon_Complete_Times) + '</td>' +
                    '</tr>';
            });
        }
        $('#dailyTableBody').html(rows);
        renderDailyPagination(res.TotalCount, page);
    });
}

function renderDailyPagination(totalCount, currentPage) {
    var pageSize = 20;
    var totalPages = Math.ceil(totalCount / pageSize);
    var html = '<div class="flex items-center justify-between mt-3 flex-wrap gap-2">' +
        '<div class="text-sm text-gray-500">총 <span class="font-semibold text-gray-700">' + totalCount.toLocaleString() + '</span>건 | 현재 페이지 : <span class="font-semibold">' + currentPage + ' / ' + totalPages + '</span></div>';

    if (totalPages > 1) {
        html += '<nav class="flex items-center gap-1 text-sm">';
        var blockSize = 10;
        var blockStart = Math.floor((currentPage - 1) / blockSize) * blockSize + 1;
        var blockEnd = Math.min(blockStart + blockSize - 1, totalPages);
        if (blockStart > 1) {
            html += '<a href="#" class="daily-page px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="1">&laquo; 처음</a>';
            html += '<a href="#" class="daily-page px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="' + (blockStart - 1) + '">&lt; 이전</a>';
        }
        for (var p = blockStart; p <= blockEnd; p++) {
            if (p === currentPage) {
                html += '<span class="px-3 py-1 rounded border border-blue-500 bg-blue-500 text-white font-semibold">' + p + '</span>';
            } else {
                html += '<a href="#" class="daily-page px-3 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="' + p + '">' + p + '</a>';
            }
        }
        if (blockEnd < totalPages) {
            html += '<a href="#" class="daily-page px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="' + (blockEnd + 1) + '">다음 &gt;</a>';
            html += '<a href="#" class="daily-page px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="' + totalPages + '">끝 &raquo;</a>';
        }
        html += '</nav>';
    }
    html += '</div>';
    $('#dailyPagination').html(html);

    $(document).off('click', '.daily-page').on('click', '.daily-page', function (e) {
        e.preventDefault();
        loadDailyList(parseInt($(this).data('page')));
    });
}
</script>
}
