@{
    ViewBag.Title = "코스별 기부 현황";
    ViewBag.Breadcrumb = Html.Raw("리딩런 &gt; <span class='font-semibold text-gray-800'>코스별 기부 현황</span>");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="space-y-4" id="donationPage">
    <!-- 페이지 헤더 -->
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-900">코스별 기부 현황</h1>
        <div class="text-sm text-gray-500">
            정보 업데이트일 : <span id="updateDatetime" class="font-medium">-</span> 기준
        </div>
    </div>

    <!-- 누적 기부 현황 요약 카드 -->
    <section>
        <h2 class="text-sm font-semibold text-gray-500 uppercase mb-3">누적 기부 현황</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="stat-card">
                <div class="text-xs text-gray-500">총 누적 기부 금액</div>
                <div class="text-2xl font-bold text-rose-600" id="totalDonationAmount">-</div>
                <div class="text-xs text-gray-400">원</div>
            </div>
            <div class="stat-card">
                <div class="text-xs text-gray-500">스타터 기부</div>
                <div class="text-xl font-bold text-blue-600" id="starterDonationAmount">-</div>
                <div class="text-xs text-gray-400">원</div>
            </div>
            <div class="stat-card">
                <div class="text-xs text-gray-500">하프 기부</div>
                <div class="text-xl font-bold text-green-600" id="halfDonationAmount">-</div>
                <div class="text-xs text-gray-400">원</div>
            </div>
            <div class="stat-card">
                <div class="text-xs text-gray-500">마라톤 기부</div>
                <div class="text-xl font-bold text-orange-600" id="marathonDonationAmount">-</div>
                <div class="text-xs text-gray-400">원</div>
            </div>
        </div>
    </section>

    <!-- 기부 이력 목록 -->
    <section>
        <div class="bg-white rounded-lg border border-gray-200">
            <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
                <h2 class="text-sm font-semibold text-gray-700">기부 이력</h2>
                <span class="text-sm text-gray-500">
                    총 <span id="totalCountDisplay" class="font-semibold text-gray-800">0</span>건
                </span>
            </div>
            <div class="overflow-x-auto">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>기부 회차</th>
                            <th>기부 일시</th>
                            <th>코스명</th>
                            <th>회원 번호</th>
                            <th>참여 회원</th>
                        </tr>
                    </thead>
                    <tbody id="donationTableBody">
                        <tr><td colspan="5" class="py-8 text-gray-400">데이터를 불러오는 중...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="px-4 pb-4" id="donationPagination"></div>
        </div>
    </section>
</div>

<!-- 참여 회원 팝업 (인라인 모달) -->
<div id="memberListModal" class="fixed inset-0 z-50 hidden flex items-center justify-center" style="background:rgba(0,0,0,0.5)">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg max-h-[80vh] flex flex-col">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
            <div>
                <h3 class="text-base font-bold text-gray-900">참여 회원</h3>
                <p class="text-xs text-gray-500 mt-0.5">기부 회차 : <span id="popupRound" class="font-medium">-</span> &nbsp;|&nbsp; 기부 일시 : <span id="popupDonationDate" class="font-medium">-</span></p>
            </div>
            <button type="button" onclick="closeMemberModal()" class="text-gray-400 hover:text-gray-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto p-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>아이디</th>
                    </tr>
                </thead>
                <tbody id="memberListBody">
                    <tr><td colspan="2" class="py-6 text-gray-400">불러오는 중...</td></tr>
                </tbody>
            </table>
            <div id="memberListPagination"></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var donationCurrentPage = 1;
var memberCurrentPage = 1;
var currentRoundNo = null;

$(function () {
    loadDonationSummary();
    loadDonationList(1);
});

function loadDonationSummary() {
    $.getJSON('/api/ReadingRun/DonationSummary', function (data) {
        $('#updateDatetime').text(BO.dateFormat(data.Update_Datetime));
        $('#totalDonationAmount').text(BO.numFormat(data.Total_Donation_Amount));
        $('#starterDonationAmount').text(BO.numFormat(data.Starter_Donation_Amount));
        $('#halfDonationAmount').text(BO.numFormat(data.Half_Donation_Amount));
        $('#marathonDonationAmount').text(BO.numFormat(data.Marathon_Donation_Amount));
    });
}

function loadDonationList(page) {
    donationCurrentPage = page;
    $('#donationTableBody').html('<tr><td colspan="5" class="py-6 text-gray-400">불러오는 중...</td></tr>');
    $.getJSON('/api/ReadingRun/DonationList', { page: page, pageSize: 20 }, function (res) {
        $('#totalCountDisplay').text((res.TotalCount || 0).toLocaleString());
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="5" class="py-8 text-gray-400">조회된 데이터가 없습니다.</td></tr>';
        } else {
            $.each(res.List, function (i, d) {
                rows += '<tr>' +
                    '<td>' + BO.numFormat(d.Course_Round_No) + '</td>' +
                    '<td>' + BO.dateFormat(d.Result_Apply_Datetime) + '</td>' +
                    '<td>' + courseLabel(d.Course_Name) + '</td>' +
                    '<td>' + BO.numFormat(d.Member_No) + '</td>' +
                    '<td><button type="button" class="text-blue-600 hover:text-blue-800 underline text-sm" onclick="openMemberModal(' + d.Course_Round_No + ', \'' + (d.Course_Name || '') + '\', \'' + (BO.dateFormat(d.Result_Apply_Datetime)) + '\')">보기</button></td>' +
                    '</tr>';
            });
        }
        $('#donationTableBody').html(rows);
        renderPagination(res.TotalCount || 0, page, '#donationPagination', loadDonationList);
    });
}

function openMemberModal(roundNo, courseName, donationDate) {
    currentRoundNo = roundNo;
    $('#popupRound').text(roundNo + ' (' + (courseName || '-') + ')');
    $('#popupDonationDate').text(donationDate || '-');
    $('#memberListModal').removeClass('hidden');
    loadMemberList(1);
}

function closeMemberModal() {
    $('#memberListModal').addClass('hidden');
    currentRoundNo = null;
}

function loadMemberList(page) {
    memberCurrentPage = page;
    $('#memberListBody').html('<tr><td colspan="2" class="py-6 text-gray-400">불러오는 중...</td></tr>');
    $.getJSON('/api/ReadingRun/DonationMembers', { Course_Round_No: currentRoundNo, page: page, pageSize: 20 }, function (res) {
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="2" class="py-6 text-gray-400">참여 회원이 없습니다.</td></tr>';
        } else {
            $.each(res.List, function (i, d) {
                rows += '<tr><td>' + ((page - 1) * 20 + i + 1) + '</td><td class="text-left">' + (d.Member_Id || d.Member_No) + '</td></tr>';
            });
        }
        $('#memberListBody').html(rows);
        renderPagination(res.TotalCount || 0, page, '#memberListPagination', loadMemberList);
    });
}

function courseLabel(name) {
    var map = { 'Starter': '<span class="badge-blue">스타터</span>', 'Half': '<span class="badge-green">하프</span>', 'Marathon': '<span class="badge-yellow">마라톤</span>' };
    return map[name] || (name || '-');
}

function renderPagination(totalCount, currentPage, containerId, callback) {
    var pageSize = 20;
    var totalPages = Math.ceil(totalCount / pageSize);
    var html = '<div class="flex items-center justify-between mt-3 flex-wrap gap-2">' +
        '<div class="text-sm text-gray-500">총 <span class="font-semibold">' + totalCount.toLocaleString() + '</span>건 | ' + currentPage + ' / ' + (totalPages || 1) + '</div>';
    if (totalPages > 1) {
        html += '<nav class="flex items-center gap-1 text-sm">';
        var blockSize = 10, blockStart = Math.floor((currentPage - 1) / blockSize) * blockSize + 1;
        var blockEnd = Math.min(blockStart + blockSize - 1, totalPages);
        if (blockStart > 1) {
            html += '<a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="1">&laquo;</a>';
            html += '<a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="' + (blockStart-1) + '">&lt;</a>';
        }
        for (var p = blockStart; p <= blockEnd; p++) {
            if (p === currentPage) html += '<span class="px-3 py-1 rounded border border-blue-500 bg-blue-500 text-white font-semibold">' + p + '</span>';
            else html += '<a href="#" class="pag-btn px-3 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="' + p + '">' + p + '</a>';
        }
        if (blockEnd < totalPages) {
            html += '<a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="' + (blockEnd+1) + '">&gt;</a>';
            html += '<a href="#" class="pag-btn px-2 py-1 rounded border text-gray-600 hover:bg-gray-100" data-page="' + totalPages + '">&raquo;</a>';
        }
        html += '</nav>';
    }
    html += '</div>';
    $(containerId).html(html);
    $(containerId).off('click', '.pag-btn').on('click', '.pag-btn', function (e) {
        e.preventDefault();
        callback(parseInt($(this).data('page')));
    });
}
</script>
}
