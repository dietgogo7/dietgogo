@{
    ViewBag.Title = "코스별 현황";
    ViewBag.Breadcrumb = Html.Raw("리딩런 &gt; <span class='font-semibold text-gray-800'>코스별 현황</span>");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="space-y-4" id="courseStatusPage">
    <!-- 페이지 헤더 -->
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-bold text-gray-900">코스별 현황</h1>
    </div>

    <!-- 검색 영역 -->
    <div class="search-box">
        <div class="flex flex-wrap gap-3 items-end">
            <!-- 코스 선택 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">코스 선택</label>
                <select id="searchCourse" class="form-select w-36">
                    <option value="">전체</option>
                    <option value="Starter">스타터</option>
                    <option value="Half">하프</option>
                    <option value="Marathon">마라톤</option>
                </select>
            </div>
            <!-- 완주 여부 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">완주 여부</label>
                <select id="searchCompleteYn" class="form-select w-32">
                    <option value="">전체</option>
                    <option value="1">완주</option>
                    <option value="0">미완주</option>
                </select>
            </div>
            <!-- 기간 (코스 시작일) -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">코스 시작일</label>
                <div class="flex items-center gap-1">
                    <input type="date" id="searchStartDate" class="form-input w-36" />
                    <span class="text-gray-400 text-sm">~</span>
                    <input type="date" id="searchEndDate" class="form-input w-36" />
                </div>
            </div>
            <!-- 회원 ID 검색 -->
            <div class="flex flex-col gap-1">
                <label class="text-xs font-medium text-gray-600">회원 ID</label>
                <input type="text" id="searchMemberId" class="form-input w-36" placeholder="회원 ID 입력" />
            </div>
            <div class="flex gap-2 items-end">
                <button type="button" id="btnSearch" class="btn-primary">검색</button>
                <button type="button" id="btnReset" class="btn-secondary">초기화</button>
                <button type="button" id="btnExcel" class="inline-flex items-center gap-1 bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded text-sm font-medium transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    엑셀 다운로드
                </button>
            </div>
        </div>
    </div>

    <!-- 조회 결과 -->
    <div class="bg-white rounded-lg border border-gray-200">
        <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
            <span class="text-sm text-gray-600">
                총 <span id="totalCountDisplay" class="font-semibold text-gray-800">0</span>건
            </span>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>번호</th>
                        <th>회원 ID</th>
                        <th>코스명</th>
                        <th>코스 회차</th>
                        <th>결과 상태</th>
                        <th>코스 시작일시</th>
                        <th>완주 여부</th>
                        <th>완주 일시</th>
                        <th>배지 지급</th>
                        <th>상품권 지급</th>
                        <th>기부 적용</th>
                        <th>등록일시</th>
                    </tr>
                </thead>
                <tbody id="courseTableBody">
                    <tr><td colspan="12" class="py-8 text-gray-400">검색 조건을 입력하고 검색 버튼을 클릭하세요.</td></tr>
                </tbody>
            </table>
        </div>
        <div class="px-4 pb-4" id="coursePagination"></div>
    </div>
</div>

@section Scripts {
<script>
var courseCurrentPage = 1;

$(function () {
    loadList(1);

    $('#btnSearch').on('click', function () { loadList(1); });
    $('#btnReset').on('click', function () {
        $('#searchCourse, #searchCompleteYn').val('');
        $('#searchMemberId').val('');
        $('#searchStartDate, #searchEndDate').val('');
        loadList(1);
    });
    $('#btnExcel').on('click', function () {
        var params = getSearchParams();
        params.excel = 1;
        window.location.href = '/api/ReadingRun/CourseStatus/Excel?' + $.param(params);
    });

    $('#searchMemberId').on('keydown', function (e) {
        if (e.key === 'Enter') loadList(1);
    });
});

function getSearchParams() {
    return {
        Course_Name:    $('#searchCourse').val(),
        Complete_Yn:    $('#searchCompleteYn').val(),
        Start_Date:     $('#searchStartDate').val(),
        End_Date:       $('#searchEndDate').val(),
        Member_Id:      $('#searchMemberId').val()
    };
}

function loadList(page) {
    courseCurrentPage = page;
    var params = getSearchParams();
    params.page = page;
    params.pageSize = 20;

    $('#courseTableBody').html('<tr><td colspan="12" class="py-8 text-gray-400">불러오는 중...</td></tr>');

    $.getJSON('/api/ReadingRun/CourseStatus', params, function (res) {
        $('#totalCountDisplay').text((res.TotalCount || 0).toLocaleString());
        var rows = '';
        if (!res.List || res.List.length === 0) {
            rows = '<tr><td colspan="12" class="py-8 text-gray-400">조회된 데이터가 없습니다.</td></tr>';
        } else {
            var startNo = (res.TotalCount || 0) - ((page - 1) * 20);
            $.each(res.List, function (i, d) {
                var completeBadge = d.Complete_Yn
                    ? '<span class="badge-green">완주</span>'
                    : '<span class="badge-gray">미완주</span>';
                var courseBadge = courseLabel(d.Course_Name);
                rows += '<tr>' +
                    '<td>' + (startNo - i) + '</td>' +
                    '<td class="text-left">' + (d.Member_Id || d.Member_No) + '</td>' +
                    '<td>' + courseBadge + '</td>' +
                    '<td>' + (d.Course_Round_No || '-') + '</td>' +
                    '<td>' + (d.Result_Status_Code || '-') + '</td>' +
                    '<td>' + BO.dateFormat(d.Course_Start_Datetime) + '</td>' +
                    '<td>' + completeBadge + '</td>' +
                    '<td>' + (d.Complete_Yn && d.Complete_Datetime ? BO.dateFormat(d.Complete_Datetime) : '-') + '</td>' +
                    '<td>' + ynBadge(d.Badge_Reward_Yn) + '</td>' +
                    '<td>' + ynBadge(d.Gift_Reward_Yn) + '</td>' +
                    '<td>' + ynBadge(d.Donation_Apply_Yn) + '</td>' +
                    '<td>' + BO.dateFormat(d.Regist_Datetime) + '</td>' +
                    '</tr>';
            });
        }
        $('#courseTableBody').html(rows);
        renderPagination(res.TotalCount || 0, page, '#coursePagination', loadList);
    });
}

function courseLabel(name) {
    var map = { 'Starter': '<span class="badge-blue">스타터</span>', 'Half': '<span class="badge-green">하프</span>', 'Marathon': '<span class="badge-yellow">마라톤</span>' };
    return map[name] || (name || '-');
}

function ynBadge(val) {
    return val ? '<span class="badge-green">Y</span>' : '<span class="badge-gray">N</span>';
}

function renderPagination(totalCount, currentPage, containerId, callback) {
    var pageSize = 20;
    var totalPages = Math.ceil(totalCount / pageSize);
    var html = '<div class="flex items-center justify-between mt-3 flex-wrap gap-2">' +
        '<div class="text-sm text-gray-500">총 <span class="font-semibold text-gray-700">' + totalCount.toLocaleString() + '</span>건 | 현재 페이지 : <span class="font-semibold">' + currentPage + ' / ' + (totalPages || 1) + '</span></div>';
    if (totalPages > 1) {
        html += '<nav class="flex items-center gap-1 text-sm">';
        var blockSize = 10;
        var blockStart = Math.floor((currentPage - 1) / blockSize) * blockSize + 1;
        var blockEnd = Math.min(blockStart + blockSize - 1, totalPages);
        if (blockStart > 1) {
            html += '<a href="#" class="pag-btn px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="1">&laquo;</a>';
            html += '<a href="#" class="pag-btn px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="' + (blockStart - 1) + '">&lt;</a>';
        }
        for (var p = blockStart; p <= blockEnd; p++) {
            if (p === currentPage) html += '<span class="px-3 py-1 rounded border border-blue-500 bg-blue-500 text-white font-semibold">' + p + '</span>';
            else html += '<a href="#" class="pag-btn px-3 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="' + p + '">' + p + '</a>';
        }
        if (blockEnd < totalPages) {
            html += '<a href="#" class="pag-btn px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="' + (blockEnd + 1) + '">&gt;</a>';
            html += '<a href="#" class="pag-btn px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="' + totalPages + '">&raquo;</a>';
        }
        html += '</nav>';
    }
    html += '</div>';
    $(containerId).html(html);
    $(containerId).off('click', '.pag-btn').on('click', '.pag-btn', function (e) {
        e.preventDefault();
        callback(parseInt($(this).data('page')));
    });
}
</script>
}
