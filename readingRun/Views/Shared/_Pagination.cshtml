@*
    Parameters (via ViewBag or Model):
    - TotalCount   : int   - 전체 건수
    - CurrentPage  : int   - 현재 페이지 (1-based)
    - PageSize     : int   - 페이지당 건수 (default 20)
    - TotalPages   : int   - 전체 페이지 수
    - PaginationId : string - 페이지네이션 컨테이너 ID (JS 콜백용)
*@
@{
    int totalCount   = ViewBag.TotalCount   ?? 0;
    int currentPage  = ViewBag.CurrentPage  ?? 1;
    int pageSize     = ViewBag.PageSize     ?? 20;
    int totalPages   = (int)Math.Ceiling((double)totalCount / pageSize);
    string pagId     = ViewBag.PaginationId ?? "pagination";

    int blockSize = 10;
    int blockStart = ((currentPage - 1) / blockSize) * blockSize + 1;
    int blockEnd   = Math.Min(blockStart + blockSize - 1, totalPages);
}
<div class="flex items-center justify-between mt-4 flex-wrap gap-2">
    <div class="text-sm text-gray-500">
        총 조회 건수 : <span class="font-semibold text-gray-700">@totalCount.ToString("N0")</span>건 &nbsp;|&nbsp;
        현재 페이지 : <span class="font-semibold text-gray-700">@currentPage / @totalPages</span>
    </div>
    @if (totalPages > 1)
    {
        <nav class="flex items-center gap-1 text-sm" id="@pagId">
            @if (blockStart > 1)
            {
                <a href="#" class="page-link px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="1">&laquo; 처음</a>
                <a href="#" class="page-link px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="@(blockStart - 1)">&lt; 이전</a>
            }
            @for (int p = blockStart; p <= blockEnd; p++)
            {
                if (p == currentPage)
                {
                    <span class="px-3 py-1 rounded border border-blue-500 bg-blue-500 text-white font-semibold">@p</span>
                }
                else
                {
                    <a href="#" class="page-link px-3 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="@p">@p</a>
                }
            }
            @if (blockEnd < totalPages)
            {
                <a href="#" class="page-link px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="@(blockEnd + 1)">다음 &gt;</a>
                <a href="#" class="page-link px-2 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-100" data-page="@totalPages">끝 &raquo;</a>
            }
        </nav>
    }
</div>
